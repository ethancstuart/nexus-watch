# ============================================================
# NexusWatch — .env.example
# Copy to .env.local and fill in values. Keep real secrets out of git.
# All runtime env vars are also set in Vercel → Project → Settings → Environment Variables.
# ============================================================

# --- Core infrastructure ---
DATABASE_URL=postgres://user:password@host/db        # Neon Postgres connection string
KV_REST_API_URL=your_kv_url_here                     # Upstash KV REST URL
KV_REST_API_TOKEN=your_kv_token_here                 # Upstash KV REST token
AUTH_SECRET=your_auth_secret                         # JWT/session signing
ADMIN_IDS=google:your_google_sub,github:your_github_id
ADMIN_EMAILS=you@example.com                         # Comma-separated admin allowlist

# --- AI providers ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here        # Claude (daily brief, sitrep, terminal)

# --- OAuth providers ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- Stripe (pricing LOCKED 2026-04-11: $29 Analyst / $99 Pro / $19 founding-100) ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_ANALYST_PRICE_ID=price_your_analyst_29_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_99_price_id
STRIPE_FOUNDING_PRICE_ID=price_your_founding_19_lifetime_price_id
STRIPE_FOUNDING_STOCK=100                            # Founding cohort cap (locked seats)
STRIPE_PRICE_ID=price_legacy_standard                # DEPRECATED — do not use for new flows
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Newsletter / Delivery ---
RESEND_API_KEY=re_your_resend_key                    # Transactional email (welcome, alerts, re-engagement)
BEEHIIV_API_KEY=your_beehiiv_api_key                 # Primary newsletter delivery (brief.nexuswatch.dev)
BEEHIIV_PUB_ID=your_beehiiv_pub_id                   # beehiiv publication ID

# --- Social automation (Track C) ---
BUFFER_ACCESS_TOKEN=your_buffer_access_token         # X/Twitter posting (daily thread + alerts)
BUFFER_PROFILE_ID=your_buffer_profile_id             # @NexusWatchDev channel ID
SOCIAL_AUTONOMY_ENABLED=false                        # Kill switch for Track C drafting engine
SOCIAL_APPROVAL_MODE=queue                           # Permanent mode — every action requires approval

# --- Discord approval channel (Chairman D-14) ---
# Phase 1 (works with plain channel webhook): just paste the webhook URL.
#   Discord → Server Settings → Integrations → Webhooks → "New Webhook" → Copy URL
DISCORD_APPROVAL_WEBHOOK_URL=                        # e.g. https://discord.com/api/webhooks/<id>/<token>
DISCORD_APPROVAL_ENABLED=true                        # Set to 'false' to silence notifications without clearing the URL
# Phase 2 (buttons inside Discord — requires a Discord Application):
#   Discord Developer Portal → Applications → (create) → General Info → copy "Public Key" + "Application ID"
#   Then set Interactions Endpoint URL to https://nexuswatch.dev/api/discord/interactions
DISCORD_APPLICATION_ID=                              # Enables Approve/Reject/Hold buttons in embeds
DISCORD_PUBLIC_KEY=                                  # Required for signature verification on button clicks
DISCORD_BOT_TOKEN=                                   # Optional: needed only if we later want to delete messages

# --- Notion (daily brief cross-post + bugs + roadmap tracking) ---
NOTION_API_KEY=your_notion_api_key

# --- Market data ---
FINNHUB_API_KEY=your_key_here
TWELVEDATA_API_KEY=your_twelvedata_key
OPENWEATHER_API_KEY=your_key_here
MAPBOX_TOKEN=your_token_here
TMDB_API_KEY=your_tmdb_api_key_here

# --- Geospatial / intel data sources ---
AISSTREAM_API_KEY=your_aisstream_api_key             # Live ship tracking + dark-vessel detection
OPENSKY_CLIENT_ID=your_opensky_client_id             # Live aircraft
OPENSKY_CLIENT_SECRET=your_opensky_client_secret

# --- Entertainment / music (optional panels) ---
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
