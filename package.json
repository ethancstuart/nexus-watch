{
  "name": "nexuswatch",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vercel dev",
    "build": "npm run typecheck && vite build && node scripts/inject-sw-manifest.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.api.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ws": "^8.18.1",
    "@vercel/node": "^5.6.11",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/browser": "^10.49.0",
    "@types/d3": "^7.4.3",
    "@vercel/og": "^0.11.1",
    "d3": "^7.9.0",
    "maplibre-gl": "^5.21.1",
    "resend": "^6.10.0",
    "rss-parser": "^3.13.0",
    "satellite.js": "^5.0.0",
    "ws": "^8.20.0"
  }
}
